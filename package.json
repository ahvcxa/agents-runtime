{
  "name": "agents-runtime",
  "version": "2.3.0",
  "description": "Vendor-neutral AI agent runtime engine — static analysis, OWASP security audit, and skill execution for any project",
  "main": "src/engine.js",
  "bin": {
    "agents": "./bin/agents.js",
    "agents-mcp": "./bin/mcp.js"
  },
  "scripts": {
    "start": "node bin/agents.js",
    "setup": "node bin/setup-interactive.js",
    "mcp": "node bin/mcp.js",
    "inject-role": "node bin/inject-role.js",
    "setup-agent": "node bin/setup-agent.js",
    "postinstall": "node bin/inject-role.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern=tests/",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch --testPathPattern=tests/",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern=tests/ --coverage",
    "lint": "node --check bin/agents.js && node --check src/engine.js src/agent-runner.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahvcxa/agents-runtime.git"
  },
  "homepage": "https://github.com/ahvcxa/agents-runtime#readme",
  "bugs": {
    "url": "https://github.com/ahvcxa/agents-runtime/issues"
  },
  "author": "Batuhan <ahvcxa>",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai-agents",
    "runtime",
    "static-analysis",
    "security-audit",
    "owasp",
    "vendor-neutral",
    "multi-agent",
    "code-analysis",
    "python",
    "javascript"
  ],
  "license": "MIT"
}
