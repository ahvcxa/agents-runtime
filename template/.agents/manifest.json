{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "spec_version": "1.0.0",
  "description": "Agent configuration manifest. Any AI agent runtime should read this file first to discover the full configuration structure of this project.",

  "entry_points": {
    "contract":  ".agents/AGENT_CONTRACT.md",
    "settings":  ".agents/settings.json",
    "startup_guide": ".agents/agent-startup.md",
    "ai_agent_guide": ".agents/AI_AGENT_GUIDE.md"
  },

  "startup_sequence": {
    "description": "Mandatory initialization sequence for AI agents. MUST complete before user interaction.",
    "required_for_ai_agents": true,
    "sequence": [
      "locate_agent_config",
      "parse_agent_yaml",
      "run_compliance_check",
      "load_settings_json",
      "initialize_memory",
      "emit_agent_initialized_event"
    ],
    "error_behavior": "hard-fail",
    "documentation": ".agents/agent-startup.md"
  },

  "suppression_syntax": "// agent-suppress: <suppression_key> reason=\"<justification>\"",

  "hooks": [
    {
      "id":          "pre-read",
      "path":        ".agents/hooks/pre-read.hook.js",
      "fires":       "before_filesystem_read",
      "description": "Validates file path against forbidden_file_patterns blocklist. Throws SecurityViolationError on match.",
      "required":    true
    },
    {
      "id":          "pre-network",
      "path":        ".agents/hooks/pre-network.hook.js",
      "export":      "preNetworkHook",
      "fires":       "before_network_access",
      "description": "Validates outbound network requests against allow-list and authorization level.",
      "required":    true
    },
    {
      "id":          "pre-skill",
      "path":        ".agents/hooks/skill-lifecycle.hook.js",
      "export":      "preSkillHook",
      "fires":       "before_skill_execution",
      "description": "Authorization check, input sanitization, distributed lock acquisition, SKILL_START event emission.",
      "required":    true
    },
    {
      "id":          "post-skill",
      "path":        ".agents/hooks/skill-lifecycle.hook.js",
      "export":      "postSkillHook",
      "fires":       "after_skill_execution",
      "description": "Lock release, result caching, SKILL_END event emission, output domain event dispatch.",
      "required":    true
    },
    {
      "id":          "pre-interaction",
      "path":        ".agents/hooks/pre-interaction.hook.js",
      "export":      "preInteractionHook",
      "fires":       "before_agent_responds_to_user",
      "description": "Verifies agent has completed initialization. Validates startup compliance. AI agents ONLY.",
      "required":    true,
      "ai_agents_only": true
    }
  ],

  "helpers": [
    {
      "id":          "compliance-check",
      "path":        ".agents/helpers/compliance-check.js",
      "description": "Startup validator. Agents MUST run this before executing any skill.",
      "usage":       "node .agents/helpers/compliance-check.js --agent-config ./agent.yaml",
      "required":    true
    },
    {
      "id":          "memory-client",
      "path":        ".agents/helpers/memory-client.js",
      "export":      "CrossAgentMemoryClient",
      "description": "Typed, access-controlled cross-agent shared memory interface.",
      "required":    false
    }
  ],

  "skills": [
    {
      "id":                      "http-request",
      "path":                    ".agents/http-request/SKILL.md",
      "version":                 "1.0.0",
      "authorization_required_level": 0,
      "bounded_context":         "Integration",
      "read_only":               true,
      "description":             "Make secure HTTP/HTTPS API calls with automatic retries, timeout protection, and credential masking."
    },
    {
      "id":                      "file-operations",
      "path":                    ".agents/file-operations/SKILL.md",
      "version":                 "1.0.0",
      "authorization_required_level": 1,
      "bounded_context":         "IO",
      "read_only":               false,
      "description":             "Read, write, append, delete files with sandbox mode. All operations restricted to /.agents/workspace/"
    },
    {
      "id":                      "system-command",
      "path":                    ".agents/system-command/SKILL.md",
      "version":                 "1.0.0",
      "authorization_required_level": 2,
      "bounded_context":         "Execution",
      "read_only":               false,
      "description":             "Execute shell commands safely with whitelist protection, no shell interpolation, timeout, and stderr capture."
    },
    {
      "id":                      "data-transform",
      "path":                    ".agents/data-transform/SKILL.md",
      "version":                 "1.0.0",
      "authorization_required_level": 0,
      "bounded_context":         "Transformation",
      "read_only":               true,
      "description":             "Safe JSON parsing, transformation, filtering, merging, and validation with circular reference detection."
    },
    {
      "id":                      "logging",
      "path":                    ".agents/logging/SKILL.md",
      "version":                 "1.0.0",
      "authorization_required_level": 0,
      "bounded_context":         "Observability",
      "read_only":               false,
      "description":             "Structured logging with automatic sensitive data masking, audit trail, and log rotation."
    },
    {
      "id":                      "code-analysis",
      "path":                    ".agents/code-analysis/SKILL.md",
      "version":                 "1.2.0",
      "authorization_required_level": 1,
      "bounded_context":         "Analysis",
      "output_event":            "AnalysisCompleted",
      "read_only":               true,
      "description":             "Static analysis: cyclomatic complexity, DRY, security-first, SOLID, cognitive complexity."
    },
    {
      "id":                      "security-audit",
      "path":                    ".agents/security-audit/SKILL.md",
      "version":                 "1.0.0",
      "authorization_required_level": 1,
      "bounded_context":         "Analysis",
      "output_event":            "SecurityAuditCompleted",
      "read_only":               true,
      "description":             "OWASP Top 10 deep scan."
    },
    {
      "id":                      "refactor",
      "path":                    ".agents/refactor/SKILL.md",
      "version":                 "1.0.0",
      "authorization_required_level": 2,
      "bounded_context":         "Transformation",
      "output_event":            "RefactoringProposed",
      "read_only":               false,
      "description":             "Consumes auto_fixable findings and produces unified diff patches."
    },
    {
      "id":                      "test-generator",
      "path":                    ".agents/test-generator/SKILL.md",
      "version":                 "1.0.0",
      "authorization_required_level": 2,
      "bounded_context":         "Testing",
      "output_event":            "TestsGenerated",
      "read_only":               false,
      "description":             "Generates test cases from analysis findings for Jest, Mocha, and Vitest workflows."
    },
    {
      "id":                      "doc-generator",
      "path":                    ".agents/doc-generator/SKILL.md",
      "version":                 "1.0.0",
      "authorization_required_level": 2,
      "bounded_context":         "Documentation",
      "output_event":            "DocumentationGenerated",
      "read_only":               false,
      "description":             "Creates project documentation such as README, API docs, and changelog outputs."
    },
    {
      "id":                      "code-formatter",
      "path":                    ".agents/code-formatter/SKILL.md",
      "version":                 "1.0.0",
      "authorization_required_level": 2,
      "bounded_context":         "Transformation",
      "output_event":            "CodeFormatted",
      "read_only":               false,
      "description":             "Applies formatting, import optimization, and unused code cleanup in preview or apply mode."
    },
    {
      "id":                      "orchestrator",
      "path":                    ".agents/orchestrator/SKILL.md",
      "version":                 "1.0.0",
      "authorization_required_level": 3,
      "bounded_context":         "Orchestration",
      "output_event":            "WorkflowCompleted",
      "read_only":               false,
      "description":             "Coordinates multi-skill execution with retry, conditional logic, projection, and aggregated reporting."
    }
  ],

  "agent_identity_schema": {
    "description": "Every agent MUST declare this structure at initialization.",
    "required_fields": ["id", "role", "authorization_level"],
    "fields": {
      "id":                  { "type": "string", "pattern": "^[a-z0-9][a-z0-9\\-_]*$" },
      "role":                { "type": "string", "enum": ["Observer", "Executor", "Orchestrator"] },
      "skill_set":           { "type": "array",  "items": { "type": "string" } },
      "authorization_level": { "type": "integer","enum": [1, 2, 3] },
      "read_only":           { "type": "boolean" },
      "read_paths":          { "type": "array",  "items": { "type": "string" } }
    }
  },

  "finding_schema": {
    "description": "Standard output object produced by analysis skills.",
    "fields": {
      "id":              { "type": "string",  "description": "uuid-v4" },
      "skill":           { "type": "string" },
      "principle":       { "type": "string" },
      "severity":        { "type": "string",  "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"] },
      "file":            { "type": "string",  "description": "Relative path from project root" },
      "line_start":      { "type": "integer" },
      "line_end":        { "type": "integer" },
      "symbol":          { "type": "string",  "description": "Function or class name" },
      "message":         { "type": "string" },
      "recommendation":  { "type": "string" },
      "cwe_id":          { "type": "string",  "description": "e.g. CWE-89" },
      "owasp_category":  { "type": "string",  "description": "e.g. A03:2021" },
      "auto_fixable":    { "type": "boolean" },
      "suppression_key": { "type": "string" }
    }
  }
}
