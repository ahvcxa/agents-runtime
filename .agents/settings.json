{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://internal/agent-settings/v1",
  "schema_version": "1.0.0",
  "description": "Canonical configuration for all autonomous agents in this project. Consumed at agent startup. Changes require Orchestrator-level authorization.",

  "runtime": {
    "environment": "development",
    "max_concurrent_agents": 4,
    "agent_timeout_seconds": 120,
    "graceful_shutdown_timeout_seconds": 15,
    "heartbeat_interval_seconds": 10,
    "sandbox": {
      "strategy": "process",
      "docker_enabled": false,
      "docker_image": "node:20-alpine",
      "docker_cpus": "1",
      "docker_memory": "256m",
      "wasm_module_path": ""
    }
  },

  "ai_agent_discovery": {
    "enabled": true,
    "description": "Configuration for AI agent (LLM-based) startup and initialization",
    "config_file": "agent.yaml",
    "search_paths": [
      "./agent.yaml",
      "../agent.yaml",
      "../../agent.yaml"
    ],
    "error_if_not_found": true,
    "startup_timeout_seconds": 30,
    "compliance_check_required": true,
    "documentation": ".agents/agent-startup.md"
  },

  "memory": {
    "description": "Cross-Agent Memory subsystem. Provides shared, indexed state accessible to authorized agents. All writes are copy-on-write to prevent race conditions.",
    "enabled": true,
    "backend": "in-process",
    "redis": {
      "url": "redis://localhost:6379"
    },
    "postgres": {
      "connection_string": "postgres://localhost:5432/agents"
    },
    "vector": {
      "provider": "none",
      "index_name": "agents_context"
    },
    "semantic_events": {
      "enabled": false,
      "top_k": 5
    },
    "max_size_mb": 256,
    "ttl_default_seconds": 3600,
    "eviction_policy": "lru",

    "indexes": {
      "key_value": {
        "enabled": true,
        "description": "Direct key-based lookup. O(1) read/write.",
        "namespace_separator": ":",
        "namespaces": {
          "agent_state":  "agent:<agent_id>:state",
          "skill_cache":  "skill:<skill_id>:cache:<hash>",
          "pipeline":     "pipeline:<run_id>:checkpoint",
          "domain_event": "event:<event_type>:<message_id>"
        },
        "max_key_length": 256,
        "max_value_size_kb": 64
      },
      "tag_based": {
        "enabled": true,
        "description": "Multi-tag indexing for semantic retrieval.",
        "max_tags_per_entry": 16,
        "reserved_tags": [
          "severity:critical", "severity:high", "severity:medium", "severity:low",
          "status:pending", "status:resolved", "status:suppressed",
          "context:analysis", "context:transformation", "context:orchestration", "context:reporting",
          "lifecycle:transient", "lifecycle:persistent"
        ],
        "query_operators": ["AND", "OR", "NOT"],
        "max_result_set": 500
      },
      "vector": {
        "enabled": false,
        "description": "Embedding-based similarity search. Disabled by default.",
        "dimensions": 1536,
        "similarity_metric": "cosine",
        "index_type": "hnsw",
        "ef_construction": 128
      }
    },

    "persistence": {
      "enabled": false,
      "storage_path": ".agents/.memory-store",
      "flush_interval_seconds": 60,
      "compression": "gzip",
      "encryption_at_rest": false
    },

    "access_control": {
      "rules": [
        {
          "namespace_pattern": "agent:*:state",
          "read_min_level": 1,
          "write_min_level": 2,
          "description": "Any agent can read peer state; only Executors+ can write state."
        },
        {
          "namespace_pattern": "skill:*:cache:*",
          "read_min_level": 1,
          "write_min_level": 1,
          "description": "Skill caches are open read/write to all agents."
        },
        {
          "namespace_pattern": "pipeline:*",
          "read_min_level": 1,
          "write_min_level": 3,
          "description": "Pipeline checkpoints are managed exclusively by Orchestrators."
        },
        {
          "namespace_pattern": "event:*",
          "read_min_level": 1,
          "write_min_level": 2,
          "description": "Domain events are written by Executors+ and readable by all."
        }
      ]
    }
  },

  "logging": {
    "output_path": ".agents/logs/agent-{date}.jsonl",
    "rotation": "daily",
    "max_retained_days": 30,
    "verbosity_mode": "standard",
    "modes": {
      "silent":     { "allowed_event_types": ["FATAL", "SECURITY_VIOLATION"] },
      "standard":   { "allowed_event_types": ["FATAL", "SECURITY_VIOLATION", "ERROR", "WARN", "SKILL_START", "SKILL_END", "HOOK_FIRE", "AUDIT", "INFO"] },
      "verbose":    { "allowed_event_types": ["FATAL", "SECURITY_VIOLATION", "ERROR", "WARN", "SKILL_START", "SKILL_END", "HOOK_FIRE", "AUDIT", "INFO", "DEBUG", "MEMORY_READ", "MEMORY_WRITE", "DOMAIN_EVENT"] },
      "audit_only": { "allowed_event_types": ["AUDIT", "SECURITY_VIOLATION"] }
    },
    "redaction": {
      "enabled": true,
      "patterns": ["password", "token", "secret", "api_key", "bearer", "authorization", "credential"],
      "replacement": "[REDACTED]"
    }
  },

  "authorization": {
    "levels": {
      "1": {
        "name": "Observer",
        "description": "Read-only agents: analyzers, linters, reporters.",
        "permissions": {
          "filesystem_read": true,  "filesystem_write": false,
          "memory_read": true,      "memory_write": false,
          "spawn_sub_agent": false, "approve_network_call": false,
          "cross_context_read": false, "emit_domain_events": true
        }
      },
      "2": {
        "name": "Executor",
        "description": "Agents that perform mutations within their bounded context.",
        "permissions": {
          "filesystem_read": true,  "filesystem_write": true,
          "memory_read": true,      "memory_write": true,
          "spawn_sub_agent": false, "approve_network_call": false,
          "cross_context_read": true, "emit_domain_events": true
        }
      },
      "3": {
        "name": "Orchestrator",
        "description": "Pipeline coordinators. May spawn and terminate sub-agents.",
        "permissions": {
          "filesystem_read": true,  "filesystem_write": true,
          "memory_read": true,      "memory_write": true,
          "spawn_sub_agent": true,  "approve_network_call": true,
          "cross_context_read": true, "emit_domain_events": true,
          "terminate_agents": true, "modify_pipeline_checkpoints": true
        }
      }
    }
  },

  "security": {
    "forbidden_file_patterns": [
      ".env", ".env.*", "*.env", "secrets/", "**/secrets/**",
      "credentials/", "**/credentials/**", "*.pem", "*.key",
      "*.p12", "*.pfx", "*.keystore", "id_rsa", "id_ed25519",
      "*.secret", "config/master.key", "config/database.yml"
    ],
    "allowed_endpoints": [],
    "enforce_content_security_policy": true,
    "input_sanitization": {
      "enabled": true,
      "max_input_length": 100000,
      "reject_null_bytes": true,
      "reject_path_traversal": true
    }
  },

  "hooks": {
    "directory": ".agents/hooks/",
    "enabled": true,
    "available": {
      "pre-skill":   "Fires before any skill execution.",
      "post-skill":  "Fires after skill execution.",
      "pre-read":    "Fires before any filesystem read. Validates path against forbidden_file_patterns.",
      "pre-network": "Fires before any outbound network call. Validates endpoint allow-list and authorization.",
      "post-write":  "Fires after any filesystem write. Triggers audit log entry.",
      "on-error":    "Fires on any unhandled agent error.",
      "on-shutdown": "Fires during graceful shutdown."
    }
  },

  "skills": {
    "registry_path": ".agents/",
    "auto_discover": true,
    "version_strategy": "semver",
    "conflict_resolution": "highest_compatible"
  }
}
