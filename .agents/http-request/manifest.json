{
  "id": "http-request",
  "version": "1.0.0",
  "name": "HTTP Request",
  "description": "Make secure HTTP/HTTPS API calls with built-in security features: SSL verification, timeouts, retry logic, and credential masking",
  "authorization_required_level": 0,
  "input": {
    "type": "object",
    "properties": {
      "method": {
        "type": "string",
        "enum": ["GET", "POST", "PUT", "DELETE", "PATCH", "HEAD", "OPTIONS"],
        "description": "HTTP method"
      },
      "url": {
        "type": "string",
        "format": "uri",
        "description": "Target URL (https recommended). Max 2048 chars."
      },
      "headers": {
        "type": "object",
        "description": "Custom HTTP headers. Authorization headers are masked in logs.",
        "additionalProperties": {
          "type": "string"
        }
      },
      "body": {
        "oneOf": [
          { "type": "string" },
          { "type": "object" }
        ],
        "description": "Request body (automatically JSON stringified if object). Max 5MB."
      },
      "timeout": {
        "type": "number",
        "default": 30000,
        "minimum": 100,
        "maximum": 300000,
        "description": "Request timeout in milliseconds (100ms - 5min). Default: 30s"
      },
      "retry": {
        "type": "object",
        "description": "Retry configuration with exponential backoff",
        "properties": {
          "maxAttempts": {
            "type": "number",
            "default": 3,
            "minimum": 1,
            "maximum": 10,
            "description": "Maximum retry attempts"
          },
          "initialDelay": {
            "type": "number",
            "default": 1000,
            "minimum": 100,
            "description": "Initial delay in milliseconds before first retry"
          },
          "backoffMultiplier": {
            "type": "number",
            "default": 2,
            "minimum": 1,
            "maximum": 10,
            "description": "Multiplier for exponential backoff"
          }
        },
        "additionalProperties": false
      },
      "allowRedirects": {
        "type": "boolean",
        "default": true,
        "description": "Follow HTTP redirects (max 5 redirects)"
      },
      "validateStatus": {
        "type": "boolean",
        "default": true,
        "description": "If true, 4xx and 5xx status codes are treated as errors"
      }
    },
    "required": ["method", "url"],
    "additionalProperties": false
  },
  "output": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean",
        "description": "true if request completed and status code indicates success"
      },
      "data": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "description": "HTTP status code (e.g., 200, 404)"
          },
          "statusText": {
            "type": "string",
            "description": "HTTP status text (e.g., 'OK', 'Not Found')"
          },
          "headers": {
            "type": "object",
            "description": "Response headers (lowercase keys)"
          },
          "body": {
            "description": "Response body (string or parsed JSON if Content-Type is application/json)"
          },
          "size": {
            "type": "integer",
            "description": "Response body size in bytes"
          }
        }
      },
      "error": {
        "type": ["object", "null"],
        "properties": {
          "code": {
            "type": "string",
            "enum": [
              "INVALID_URL",
              "NETWORK_TIMEOUT",
              "NETWORK_ERROR",
              "SSL_ERROR",
              "HTTP_ERROR",
              "RESPONSE_TOO_LARGE",
              "INVALID_JSON",
              "REDIRECT_LIMIT_EXCEEDED",
              "MAX_RETRIES_EXCEEDED",
              "UNSUPPORTED_PROTOCOL"
            ],
            "description": "Error code"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message (no credentials)"
          },
          "details": {
            "type": "object",
            "description": "Additional error context (safe details only)"
          }
        }
      },
      "metadata": {
        "type": "object",
        "properties": {
          "executionTime": {
            "type": "number",
            "description": "Total execution time in milliseconds"
          },
          "timestamp": {
            "type": "string",
            "description": "ISO 8601 timestamp of request"
          },
          "retries": {
            "type": "number",
            "description": "Number of retries performed before success/failure"
          },
          "redirects": {
            "type": "number",
            "description": "Number of redirects followed"
          },
          "dnsLookupTime": {
            "type": "number",
            "description": "DNS lookup time in milliseconds (if available)"
          }
        }
      }
    }
  },
  "examples": [
    {
      "name": "Simple GET Request",
      "input": {
        "method": "GET",
        "url": "https://api.example.com/users/123"
      },
      "output": {
        "success": true,
        "data": {
          "status": 200,
          "statusText": "OK",
          "headers": { "content-type": "application/json" },
          "body": { "id": 123, "name": "John" },
          "size": 45
        },
        "error": null,
        "metadata": {
          "executionTime": 245,
          "timestamp": "2026-04-07T12:34:56.789Z",
          "retries": 0
        }
      }
    },
    {
      "name": "POST with Custom Headers",
      "input": {
        "method": "POST",
        "url": "https://api.example.com/data",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer your-token-here"
        },
        "body": { "key": "value" }
      },
      "output": {
        "success": true,
        "data": {
          "status": 201,
          "statusText": "Created",
          "body": { "id": "new-id" }
        },
        "error": null,
        "metadata": {
          "executionTime": 312,
          "timestamp": "2026-04-07T12:35:00.000Z",
          "retries": 0
        }
      }
    },
    {
      "name": "Timeout Error",
      "input": {
        "method": "GET",
        "url": "https://slow-api.example.com/data",
        "timeout": 5000
      },
      "output": {
        "success": false,
        "data": null,
        "error": {
          "code": "NETWORK_TIMEOUT",
          "message": "Request timed out after 5000ms"
        },
        "metadata": {
          "executionTime": 5001,
          "timestamp": "2026-04-07T12:36:00.000Z",
          "retries": 0
        }
      }
    }
  ],
  "security_notes": [
    "SSL certificates are ALWAYS verified. Set NODE_TLS_REJECT_UNAUTHORIZED=0 only in development.",
    "Authorization headers and sensitive cookies are masked in logs and error messages.",
    "Requests follow max 5 redirects by default. Use allowRedirects=false to disable.",
    "Response body size is limited to 50MB to prevent memory exhaustion.",
    "Request body size is limited to 5MB to prevent server overload.",
    "Timeouts default to 30 seconds. Set timeout explicitly for shorter/longer operations.",
    "Retry logic uses exponential backoff to prevent overwhelming servers.",
    "Only HTTPS is recommended. HTTP requests work but are insecure.",
    "Domain whitelist can be configured in settings.json (http_allowed_domains)."
  ]
}
